section .data
    msg db "Looping...",10
    len equ $-msg

section .text
    global _start

_start:
    mov rcx, 5

loop_start:
    ; display message
    mov rax, 1
    mov rdi, 1
    mov rsi, msg
    mov rdx, len
    syscall

    dec rcx
    jnz loop_start

    mov rax, 60
    xor rdi, rdi
    syscall
